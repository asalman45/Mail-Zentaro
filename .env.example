# Zentaro Email Server Configuration
PORT=4500
NODE_ENV=production

# MongoDB (use the same VPS MongoDB, separate database)
MONGODB_URI=mongodb://localhost:27017/zentaro-email

# JWT Secret for Admin Auth (generate a random string)
JWT_SECRET=your_jwt_secret_here_change_this

# Admin Credentials (used on first login to auto-create admin)
ADMIN_EMAIL=admin@zentaro.pk
ADMIN_PASSWORD=change_this_password

# SMTP Configuration (Fresh Brevo Account for Zentaro)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your_NEW_brevo_smtp_login@smtp-brevo.com
SMTP_PASSWORD=your_NEW_brevo_smtp_password

# Cloudflare Email Webhook Secret (must match the Worker)
EMAIL_WEBHOOK_SECRET=ZentaroEmailSecret2026!

# Frontend URL (for CORS)
FRONTEND_URL=https://zentaro.pk
